{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "codex": {
      "type": "local",
      "command": ["npx", "-y", "codex", "mcp-server"],
      "enabled": true,
      "timeout": 5000
    }
  },
  "agent": {
    "quest": {
      "description": "Quest orchestration agent - coordinates plan/review/build/fix workflow",
      "mode": "primary",
      "model": "opencode/kimi-k2.5",
      "steps": 35,
      "prompt": "{file:agents/quest.md}",
      "permission": {
        "task": {
          "*": "deny",
          "planner": "allow",
          "plan-reviewer-a": "allow",
          "plan-reviewer-b": "allow",
          "arbiter": "allow",
          "builder": "allow",
          "code-reviewer-a": "allow",
          "code-reviewer-b": "allow",
          "fixer": "allow"
        },
        "edit": {
          "*": "deny",
          ".quest/**": "allow"
        }
      }
    },
    "planner": {
      "description": "Creates implementation plans from quest briefs",
      "mode": "subagent",
      "model": "opencode/claude-opus-4-6",
      "prompt": "{file:agents/planner.md}",
      "permission": {
        "edit": {
          "*": "deny",
          ".quest/**": "allow"
        },
        "bash": "deny"
      }
    },
    "plan-reviewer-a": {
      "description": "Reviews implementation plans (Reviewer A - Codex via MCP)",
      "mode": "subagent",
      "model": "opencode/kimi-k2.5",
      "prompt": "{file:agents/plan-reviewer.md}",
      "permission": {
        "edit": {
          "*": "deny",
          ".quest/**": "allow"
        },
        "bash": "deny"
      }
    },
    "plan-reviewer-b": {
      "description": "Reviews implementation plans (Reviewer B - Codex)",
      "mode": "subagent",
      "model": "opencode/gpt-5.4",
      "prompt": "{file:agents/plan-reviewer.md}",
      "permission": {
        "edit": {
          "*": "deny",
          ".quest/**": "allow"
        },
        "bash": "deny"
      }
    },
    "arbiter": {
      "description": "Synthesizes dual reviews, renders APPROVE or ITERATE verdict",
      "mode": "subagent",
      "model": "opencode/claude-opus-4-6",
      "prompt": "{file:agents/arbiter.md}",
      "permission": {
        "edit": {
          "*": "deny",
          ".quest/**": "allow"
        },
        "bash": "deny"
      }
    },
    "builder": {
      "description": "Implements approved plans (can invoke Codex via MCP)",
      "mode": "subagent",
      "model": "opencode/kimi-k2.5",
      "prompt": "{file:agents/builder.md}",
      "permission": {
        "edit": {
          "*": "deny",
          ".quest/**": "allow",
          "src/**": "allow",
          "lib/**": "allow",
          "tests/**": "allow",
          "scripts/**": "allow",
          "docs/**": "allow",
          "*.md": "allow",
          "*.json": "allow"
        },
        "bash": {
          "*": "ask",
          "npm test*": "allow",
          "pytest*": "allow",
          "python*": "allow"
        }
      }
    },
    "code-reviewer-a": {
      "description": "Reviews code changes (Reviewer A - KiMi)",
      "mode": "subagent",
      "model": "opencode/kimi-k2.5",
      "prompt": "{file:agents/code-reviewer.md}",
      "permission": {
        "edit": {
          "*": "deny",
          ".quest/**": "allow"
        },
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        }
      }
    },
    "code-reviewer-b": {
      "description": "Reviews code changes (Reviewer B - Codex)",
      "mode": "subagent",
      "model": "opencode/gpt-5.4",
      "prompt": "{file:agents/code-reviewer.md}",
      "permission": {
        "edit": {
          "*": "deny",
          ".quest/**": "allow"
        },
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        }
      }
    },
    "fixer": {
      "description": "Addresses code review feedback",
      "mode": "subagent",
      "model": "opencode/claude-opus-4-6",
      "prompt": "{file:agents/fixer.md}",
      "permission": {
        "edit": {
          "*": "deny",
          ".quest/**": "allow",
          "src/**": "allow",
          "lib/**": "allow",
          "tests/**": "allow",
          "scripts/**": "allow",
          "docs/**": "allow",
          "*.md": "allow",
          "*.json": "allow"
        },
        "bash": {
          "*": "ask",
          "npm test*": "allow",
          "pytest*": "allow",
          "python*": "allow"
        }
      }
    }
  },
  "command": {
    "quest": {
      "template": "$ARGUMENTS",
      "description": "Run Quest multi-agent orchestration workflow",
      "agent": "quest"
    },
    "celebrate": {
      "template": "{file:commands/celebrate.md} Quest: $ARGUMENTS",
      "description": "Play quest completion celebration"
    }
  }
}
