{
  "version": 2,
  "description": "Creator-managed permissions for quest orchestration. Edit this file to pre-approve or restrict quest agent actions. Changes take effect on next quest run.",
  "quest_completion": {
    "enabled": true,
    "animation_style": "epic",
    "show_end_credits": true,
    "show_progress_bars": true,
    "ascii_art": true,
    "animation_speed": "default",
    "safe_mode": "auto"
  },
  "auto_approve_phases": {
    "plan_creation": true,
    "plan_review": true,
    "plan_refinement": true,
    "implementation": false,
    "code_review": true,
    "fix_loop": true
  },
  "models": {
    "planner": "gpt-5.4",
    "plan-reviewer-a": "claude",
    "plan-reviewer-b": "gpt-5.4",
    "arbiter": "claude",
    "builder": "gpt-5.4",
    "code-reviewer-a": "claude",
    "code-reviewer-b": "gpt-5.4",
    "fixer": "gpt-5.4"
  },
  "quest_startup": {
    "branch_mode": "branch",
    "branch_prefix": "quest/",
    "worktree_root": ".worktrees/quest"
  },
  "review_mode": "full",
  "fast_review_thresholds": {
    "max_files": 5,
    "max_loc": 300
  },
  "role_permissions": {
    "planner_agent": {
      "file_write": [".quest/**", "docs/**", "ideas/**", ".ai/**", "*.md"],
      "file_read": ["**"],
      "bash": ["find", "rg", "grep", "wc", "ls", "tree", "git status", "git diff", "gh pr view.*"]
    },
    "plan_review_a": {
      "file_write": [".quest/**"],
      "file_read": ["**"],
      "bash": ["python", "python3", "pytest", "git status", "git diff", "git log", "rg", "grep", "find", "ls", "wc", "uv", "gh pr view.*"]
    },
    "plan_review_b": {
      "file_write": [".quest/**"],
      "file_read": ["**"],
      "bash": ["python", "python3", "pytest", "git status", "git diff", "git log", "rg", "grep", "find", "ls", "wc", "uv", "gh pr view.*"]
    },
    "arbiter_agent": {
      "file_write": [".quest/**"],
      "file_read": ["**"],
      "bash": ["git status", "git diff", "gh pr view.*"]
    },
    "builder_agent": {
      "file_write": [".quest/**", ".ai/**", ".github/**", "docs/**", "ideas/**", "scripts/**", "tests/**", ".skills/**", "*.md", "*.json", "*.txt", "*.sh", "*.py"],
      "file_read": ["**"],
      "bash": ["python", "python3", "python3 -m unittest", "pytest", "bash", "git status", "git diff", "git log", "npm test", "rg", "grep", "find", "ls", "wc"]
    },
    "code_review_agent": {
      "file_write": [".quest/**"],
      "file_read": ["**"],
      "bash": ["python", "python3", "pytest", "git diff", "git log", "git status", "rg", "grep", "find", "ls", "wc", "uv", "gh pr view.*"]
    },
    "fixer_agent": {
      "file_write": [".quest/**", ".ai/**", ".github/**", "docs/**", "ideas/**", "scripts/**", "tests/**", ".skills/**", "*.md", "*.json", "*.txt", "*.sh", "*.py"],
      "file_read": ["**"],
      "bash": ["python", "python3", "python3 -m unittest", "pytest", "bash", "git status", "git diff", "git log", "npm test", "rg", "grep", "find", "ls", "wc"]
    }
  },
  "solo": {
    "max_fix_iterations": 2
  },
  "gates": {
    "require_approval_before_commit": true,
    "require_approval_before_push": true,
    "require_approval_before_delete": true,
    "max_plan_iterations": 4,
    "max_fix_iterations": 3
  }
}
