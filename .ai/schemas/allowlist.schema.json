{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quest Allowlist Configuration",
  "description": "Creator-managed permissions for quest orchestration.",
  "type": "object",
  "required": ["version", "auto_approve_phases", "review_mode", "role_permissions", "gates"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "auto_approve_phases": {
      "type": "object",
      "properties": {
        "plan_creation": { "type": "boolean" },
        "plan_review": { "type": "boolean" },
        "plan_refinement": { "type": "boolean" },
        "implementation": { "type": "boolean" },
        "code_review": { "type": "boolean" },
        "fix_loop": { "type": "boolean" }
      }
    },
    "quest_completion": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "animation_style": { "type": "string" },
        "show_end_credits": { "type": "boolean" },
        "show_progress_bars": { "type": "boolean" },
        "ascii_art": { "type": "boolean" },
        "animation_speed": { "type": "string" },
        "safe_mode": { "type": "string" }
      }
    },
    "models": {
      "type": "object",
      "propertyNames": {
        "enum": ["planner", "plan-reviewer-a", "plan-reviewer-b", "arbiter", "builder", "code-reviewer-a", "code-reviewer-b", "fixer"]
      },
      "additionalProperties": { "type": "string" }
    },
    "quest_startup": {
      "type": "object",
      "properties": {
        "branch_mode": {
          "type": "string",
          "enum": ["branch", "worktree", "none"]
        },
        "branch_prefix": { "type": "string" },
        "worktree_root": { "type": "string" }
      }
    },
    "review_mode": { "type": "string", "enum": ["auto", "fast", "full"] },
    "fast_review_thresholds": {
      "type": "object",
      "properties": {
        "max_files": { "type": "integer", "minimum": 1 },
        "max_loc": { "type": "integer", "minimum": 1 }
      }
    },
    "role_permissions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "file_write": { "type": "array", "items": { "type": "string" } },
          "file_read": { "type": "array", "items": { "type": "string" } },
          "bash": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "solo": {
      "type": "object",
      "properties": {
        "max_fix_iterations": { "type": "integer", "minimum": 1 },
        "notes": { "type": "string" }
      }
    },
    "update_check": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "interval_days": { "type": "integer", "minimum": 1 }
      }
    },
    "gates": {
      "type": "object",
      "properties": {
        "require_approval_before_commit": { "type": "boolean" },
        "require_approval_before_push": { "type": "boolean" },
        "require_approval_before_delete": { "type": "boolean" },
        "max_plan_iterations": { "type": "integer", "minimum": 1 },
        "max_fix_iterations": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
